{
  "name": "estuda-plus",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "node --watch server/index.js",
    "dev:web": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "start": "node server/index.js",
    "backup:export": "node scripts/migrate-online.js export",
    "backup:restore": "node scripts/migrate-online.js restore",
    "backup:migrate": "node scripts/migrate-online.js migrate",
    "db:migrate:neon": "node scripts/migrate-to-postgres.js --yes",
    "questions:import": "node scripts/migrate-online.js import-questions"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "better-sqlite3": "^11.7.0",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "pg": "^8.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.3"
  }
}
